<nav
  class="
    navbar
    fixed-top
    navbar-expand-lg navbar-<%-
    theme
    %>
    nav-fixed nav-class
  "
>
  <div class="container">
    <!-- <a class="navbar-brand" href="#"><h1>Multroic</h1></a> -->
    <a class="navbar-brand" href="/">
      <img
        src="/assets/img/text-logo.svg"
        width="80%"
        class="d-inline-block align-top"
        alt=""
      />
    </a>
    <button
      class="navbar-toggler"
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#navbarNav"
      aria-controls="navbarNav"
      aria-expanded="false"
      aria-label="Toggle navigation"
    >
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse text-center" id="navbarNav">
      <div class="mx-auto"></div>
      <ul class="navbar-nav">
        <li class="nav-item" style="padding: 8px 0px">
          <a class="nav-link" href="/">Home</a>
        </li>
        <li class="nav-item" style="padding: 8px 0px">
          <a class="nav-link" href="/games">Games</a>
        </li>
        <li class="nav-item" style="padding: 8px 0px">
          <a class="nav-link" href="/about">About</a>
        </li>
        <li class="nav-item" style="padding: 8px 0px">
          <a class="nav-link" href="/contact">Contact</a>
        </li>
        <% if (user) { %>

        <li class="nav-item dropdown">
          <a
            class="nav-link dropdown-toggle"
            style="margin-left: 10px"
            href="#"
            id="navbarDropdownMenuLink"
            data-toggle="dropdown"
            aria-haspopup="true"
            aria-expanded="false"
          >
            <img
              src="
                <% if (avatar) { %>
                  <%= avatar.avatar %>
                <% } else { %>
                /assets/img/avatars/SVG/default.svg
                <% } %> 
                "
              alt="<%= user.username %>"
              width="40px"
            />

            <%= user.username %>
          </a>
          <div class="dropdown-menu" aria-labelledby="navbarDropdownMenuLink">
            <a class="dropdown-item" href="/profile/<%= user.username %>"
              >Profile</a
            >
            <a class="dropdown-item" href="/logout">Logout</a>
          </div>
        </li>
        <% } else { %>
        <li>
          <a
            href="/login"
            class="btn btn-login-register btn-light btn-block btn-md"
            data-toggle="modal"
            data-target="#login-register"
            >Login / Register</a
          >
        </li>
        <% } %>
      </ul>
    </div>
  </div>
</nav>

<div
  class="modal fade"
  id="login-register"
  tabindex="-1"
  role="dialog"
  aria-labelledby="exampleModalLabel"
  aria-hidden="true"
>
  <div class="modal-dialog" role="document">
    <div class="modal-content">
      <!-- <div class="modal-header">
          <h5 class="modal-title" id="exampleModalLabel">Modal title</h5>
            <button type="button" class="btn">
                <span aria-hidden="true">&times;</span>
            </button>

        </div> -->
      <div class="modal-body">
        <ul class="nav nav-tabs" id="myTab" role="tablist">
          <li class="nav-item" role="presentation">
            <button
              class="nav-link active"
              id="login-tab"
              data-bs-toggle="tab"
              data-bs-target="#login"
              type="button"
              role="tab"
              aria-controls="login"
              aria-selected="true"
            >
              <h5>Login <i class="fas fa-user"></i></h5>
            </button>
          </li>
          <li class="nav-item" role="presentation">
            <button
              class="nav-link"
              id="register-tab"
              data-bs-toggle="tab"
              data-bs-target="#register"
              type="button"
              role="tab"
              aria-controls="register"
              aria-selected="false"
            >
              <h5>Register <i class="fas fa-user-plus"></i></h5>
            </button>
          </li>
          <!-- <li class="nav-item" role="presentation">
            <button
              class="nav-link"
              id="why-tab"
              data-bs-toggle="tab"
              data-bs-target="#why"
              type="button"
              role="tab"
              aria-controls="why"
              aria-selected="false"
            >
              <h5>Why? <i class="fas fa-question-circle"></i></h5>
            </button>
          </li> -->
          <li>
            <button type="button" class="btn close" data-dismiss="modal">
              <h1><span aria-hidden="true">&times;</span></h1>
            </button>
          </li>
        </ul>

        <div class="tab-content" id="myTabContent">
          <div
            class="tab-pane fade show active"
            id="login"
            role="tabpanel"
            aria-labelledby="login-tab"
          >
            <form class="login-form">
              <div class="form-group pb-2">
                <label for="email"><h6>Email</h6></label>
                <input
                  type="email"
                  class="form-control form-control-lg"
                  id="email"
                  name="email"
                  aria-describedby="emailHelp"
                />
              </div>
              <div class="email error"></div>
              <div class="form-group py-2">
                <label for="password"><h6>Password</h6></label>
                <a href="/auth/requestResetPassword" style="float: right; font-size: 12px"
                  >Forgot password?</a
                >
                <input
                  type="password"
                  class="form-control form-control-lg"
                  id="password"
                  name="password"
                />
              </div>
              <div class="password error"></div>
              <button type="submit" class="btn btn-primary btn-block">
                Log in
              </button>

              <div class="sign-up">
                Don't have an account?
                <a href="#" class="create-account-link">Create Account</a>
              </div>
            </form>
          </div>

          <div
            class="tab-pane fade"
            id="register"
            role="tabpanel"
            aria-labelledby="register-tab"
          >
            <form class="signup-form">
              <div class="form-group pb-2">
                <label for="username"><h6>Username</h6></label>
                <input
                  type="text"
                  class="form-control form-control-lg"
                  id="username"
                  name="signupUsername"
                />
                <div class="signup username error"></div>
              </div>

              <div class="form-group pb-2">
                <label for="email"><h6>Email</h6></label>
                <input
                  type="email"
                  class="form-control form-control-lg"
                  id="signup-email"
                  name="signupEmail"
                  aria-describedby="emailHelp"
                />
              </div>
              <div class="signup email error"></div>

              <div class="form-group py-2">
                <label for="password"><h6>Password</h6></label>
                <a href="/auth/requestResetPassword" style="float: right; font-size: 12px"
                  >Forgot password?</a
                >
                <input
                  type="password"
                  class="form-control form-control-lg"
                  id="signup-password"
                  name="signupPassword"
                />
              </div>
              <div class="signup password error"></div>
              <button type="submit" class="btn btn-primary btn-block">
                Sign Up
              </button>

              <div class="sign-up">
                Already have an account?
                <a href="#" class="login-account-link">Login here</a>
              </div>
            </form>
          </div>
          <!-- <div
            class="tab-pane fade"
            id="why"
            role="tabpanel"
            aria-labelledby="why-tab"
          >
            Why?
          </div> -->
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-dismiss="modal">
          Close
        </button>
      </div>
    </div>
  </div>
</div>


